# Build artifacts
/server/bin/
/server/dist/
/server/internal/web/dist/*
!/server/internal/web/dist/.gitkeep
/client/dist/
/client/.tanstack/
/node_modules/

# Go
/server/vendor/
*.test
*.out
coverage.*

# Data (runtime - lives at XDG paths, but ignore any local ./data overrides)
/data/
*.duckdb
*.duckdb.wal
*.parquet

# Editors / OS
.DS_Store
.vscode/
.idea/
*.swp
*~

# Env
.env
.env.local
/.ai/
.superpowers/
/.mcp.json

# Bundled MediaMTX relay binary for the game preview (downloaded, not committed)
/mediamtx_*/
# MediaMTX runtime-generated TLS certs (created in CWD on first run)
/auto.crt
/auto.key
